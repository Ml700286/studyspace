          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 预处理程序">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.util.concurrent.ThreadLocalRandom
// 定义开始和结束时间
def rand = ThreadLocalRandom.current()
def start=8*60+30
def end=22*60+40
// 定义范围
def start_rand=rand.nextInt(start,end+1)
def end_rand=rand.nextInt(start_rand+1,end+1)
// 转换成时间格式
def startTime_H=start_rand.intdiv(60)
def startTime_M=start_rand%60
def endTime_H=end_rand.intdiv(60)
def endTime_M=end_rand%60

def start_time=String.format(&quot;%02d:%02d:00&quot;,startTime_H,startTime_M)
def end_time=String.format(&quot;%02d:%02d:00&quot;,endTime_H,endTime_M)
vars.put(&quot;startTime&quot;,start_time)
vars.put(&quot;endTime&quot;,end_time)
log.info(&quot;生成时间: startTime=&quot; + vars.get(&quot;startTime&quot;) + &quot;, endTime=&quot; + vars.get(&quot;endTime&quot;))


</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
