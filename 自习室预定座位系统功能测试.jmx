          <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="BeanShell 后置处理程序" enabled="false">
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="script">// 从变量中获取token
String token = vars.get(&quot;token&quot;);

// 检查token是否有效
if (token != null &amp;&amp; !token.equals(&quot;NOT_FOUND&quot;) &amp;&amp; !token.isEmpty()) {
    // 存入全局属性
    props.put(&quot;login_token&quot;, token);
    log.info(&quot;Token saved successfully: &quot; + token);
} else {
    log.warn(&quot;Token extraction failed, value: &quot; + token);
}</stringProp>
          </BeanShellPostProcessor>
          <hashTree/>
        </hashTree>
