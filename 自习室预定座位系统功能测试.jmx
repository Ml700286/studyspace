&quot;date&quot;:&quot;${__RandomDate(yyyy-MM-dd,2026-07-03,2026-08-03,,)}&quot;,&#xd;
&quot;startTime&quot;:&quot;${startTime}&quot;,&#xd;
&quot;endTime&quot;:&quot;${endTime}&quot;,&#xd;
&quot;roomId&quot;: ${__Random(1,6,)},&#xd;
&quot;seatId&quot;: ${__Random(1,40,)}&#xd;
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
